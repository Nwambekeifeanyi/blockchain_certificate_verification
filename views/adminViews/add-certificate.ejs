    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mint & Upload Certificate | CertiGuard</title>
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            navy: '#0A192F',       // Primary Dark Canvas
                            cyan: '#00F0FF',       // Security Accent Cyan
                            teal: '#0D9488',       // Secondary Operations Teal
                            slate: '#F8FAFC',      // Light Panel Backgrounds
                            charcoal: '#334155',   // Text Typography Slate
                        }
                    }
                }
            }
        }
    </script>

    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
