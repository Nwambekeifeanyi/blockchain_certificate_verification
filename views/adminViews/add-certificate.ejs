    <!-- AOS ANIMATION INITIALIZATION & INTERACTIVE SCRIPTS -->
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="/formHandlers/add-certificate.js"></script>
    <script>
        AOS.init({
            once: true,
            duration: 500,
            easing: 'ease-out-quad'
        });

        // ==========================================
        // DRAG & DROP FILE INTERACTION SCRIPT HANDLER
        // ==========================================
        const dropzone = document.getElementById('dropzone');
        const fileInput = document.getElementById('certificateFile');
        const promptState = document.getElementById('dropzone-prompt');
        const successState = document.getElementById('dropzone-success');
        const nameDisplay = document.getElementById('file-name-display');
        const resetBtn = document.getElementById('reset-btn');

        // Drag events hooks toggling custom visual classes
        ['dragenter', 'dragover'].forEach(eventName => {
            dropzone.addEventListener(eventName, (e) => {
                e.preventDefault();
                dropzone.classList.add('drag-over');
            }, false);
        });

        ['dragleave', 'drop'].forEach(eventName => {
            dropzone.addEventListener(eventName, (e) => {
                e.preventDefault();
                dropzone.classList.remove('drag-over');
            }, false);
        });

        // Track file capture and update visible layout interface elements
        fileInput.addEventListener('change', (e) => {
            handleFileSelection(fileInput.files[0]);
        });

        function handleFileSelection(file) {
            if (file) {
                nameDisplay.textContent = file.name;
                promptState.classList.add('hidden');
                successState.classList.remove('hidden');
                dropzone.classList.add('border-emerald-500', 'bg-emerald-50/10');
            }
        }

        // Handle clear forms triggers resetting components
        resetBtn.addEventListener('click', () => {
            promptState.classList.remove('hidden');
            successState.classList.add('hidden');
            dropzone.className = "relative border-2 border-dashed border-slate-200 hover:border-brand-teal bg-brand-slate rounded-2xl p-6 text-center transition-all cursor-pointer group flex flex-col items-center justify-center min-h-[160px]";
        });
    </script>
