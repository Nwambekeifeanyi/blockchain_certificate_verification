                        <div id="dropzone" class="relative border-2 border-dashed border-slate-200 hover:border-brand-teal bg-brand-slate rounded-2xl p-6 text-center transition-all cursor-pointer group flex flex-col items-center justify-center min-h-[160px]">
                            <input type="file" id="certificateFile" name="certificateFile" accept=".pdf,.png,.jpg,.jpeg" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                            
                            <!-- Static Initial Visual Content State -->
                            <div id="dropzone-prompt" class="space-y-2 pointer-events-none transition-all duration-300">
