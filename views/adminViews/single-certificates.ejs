<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Issued Certificate Verification View | CertiGuard</title>
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            navy: '#0A192F',       // Primary Dark Canvas
                            cyan: '#00F0FF',       // Security Accent Cyan
                            teal: '#0D9488',       // Secondary Operations Teal
                            slate: '#F8FAFC',      // Light Panel Backgrounds
                            charcoal: '#334155',   // Text Typography Slate
                        }
                    }
                }
            }
        }
    </script>

    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Google Fonts for Certificate Authenticity Style -->
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@600;800&family=Playfair+Display:ital,wght@0,600;1,400&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">

    <!-- AOS (Animate on Scroll) CSS -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <style>
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #0A192F;
        }
        ::-webkit-scrollbar-thumb {
            background: #0D9488;
            border-radius: 10px;
        }
        .custom-shadow {
            box-shadow: 0 10px 30px -15px rgba(2, 12, 27, 0.2);
        }
        .certificate-title { font-family: 'Cinzel', serif; }
        .certificate-body { font-family: 'Playfair Display', serif; }
        .mono-text { font-family: 'JetBrains Mono', monospace; }
        
        /* Print Styles to isolate the certificate window cleanly if downloaded */
        @media print {
            body * { visibility: hidden; }
            #printable-certificate, #printable-certificate * { visibility: visible; }
            #printable-certificate { position: absolute; left: 0; top: 0; width: 100%; border: none; box-shadow: none; }
        }
    </style>
</head>
<body class="bg-slate-100 text-brand-charcoal font-sans antialiased flex min-h-screen selection:bg-brand-cyan selection:text-brand-navy">

    <!-- SIDEBAR NAVIGATION PANEL (Hidden on mobile, persistent on desktop) -->
   <!-- nav bar -->
    <%- include('../snippets/adminNav.ejs') %>

    <!-- CONTENT WRAPPER CANVAS REGION -->
    <div class="flex-grow lg:pl-64 flex flex-col min-h-screen">
        
    <!-- DASHBOARD ACTION GLOBAL TOPBAR -->
    <%- include('../snippets/adminTop.ejs') %>


        <!-- DASHBOARD METRIC SECTIONS & APPLICATION MODULE VIEWS -->
        <main class="p-4 md:p-8 flex-grow space-y-8 overflow-x-hidden">
            
            <!-- OVERVIEW PERFORMANCE COUNTER MATRICES -->
            <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" data-aos="fade-up">
                <!-- Card Count 1 -->
                <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm flex items-center justify-between">
                    <div class="space-y-1">
                        <p class="text-xs font-bold tracking-wider text-slate-400 uppercase">Verification Status</p>
                        <h3 class="text-2xl font-black text-emerald-600 flex items-center gap-1.5">
                            <i class="fa-regular fa-circle-check text-xl"></i> Verified
                        </h3>
                    </div>
                    <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center text-xl shadow-inner">
                       <i class="fa-solid fa-shield-halved"></i>
                    </div>
                </div>
                <!-- Card Count 2 -->
                <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm flex items-center justify-between">
                    <div class="space-y-1">
                        <p class="text-xs font-bold tracking-wider text-slate-400 uppercase">Database Queries</p>
                        <h3 class="text-3xl font-black text-brand-navy">124</h3>
                    </div>
                    <div class="w-12 h-12 bg-brand-navy/5 text-brand-teal rounded-xl flex items-center justify-center text-xl shadow-inner">
                        <i class="fa-solid fa-magnifying-glass-chart"></i>
                    </div>
                </div>
                <!-- Card Count 3 -->
                <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm flex items-center justify-between sm:col-span-2 lg:col-span-1">
                    <div class="space-y-1">
                        <p class="text-xs font-bold tracking-wider text-slate-400 uppercase">Integrity Anchor</p>
                        <h3 class="text-sm font-bold text-brand-teal tracking-tight font-mono truncate max-w-[180px]">MongoDB Node_01</h3>
                    </div>
                    <div class="w-12 h-12 bg-brand-navy/5 text-brand-teal rounded-xl flex items-center justify-center text-xl shadow-inner">
                        <i class="fa-solid fa-link"></i>
                    </div>
                </div>
            </section>

            <!-- WORKSPACE SPLIT BI-GRID: CERTIFICATE DISPLAY VIEW & DATABASE LOGS -->
            <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
                
                <!-- MODULE 1 BLOCK: DIGITAL SECURE CERTIFICATE CANVAS (3 Columns wide for visual priority) -->
                <section class="lg:col-span-3 space-y-4" data-aos="fade-right">
                    
                    <!-- Action Row Tooling -->
                    <div class="flex items-center justify-between bg-white p-4 rounded-xl border border-slate-200 shadow-sm">
                        <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Document Token: #CG-2026-091</span>
                        <button onclick="window.print()" class="bg-brand-navy hover:bg-brand-navy/95 text-white text-xs font-bold py-2 px-4 rounded-lg flex items-center space-x-2 transition-all">
                            <i class="fa-solid fa-print"></i>
                            <span>Print / Save PDF</span>
                        </button>
                    </div>

                    <!-- Certificate Canvas Frame container -->
                    <div id="printable-certificate" class="bg-white p-8 md:p-12 rounded-2xl border-4 border-double border-brand-navy shadow-md relative overflow-hidden bg-[radial-gradient(#e2e8f0_1px,transparent_1px)] [background-size:16px_16px]">
                        <!-- Elegant Corner Accents -->
                        <div class="absolute top-4 left-4 w-12 h-12 border-t-2 border-l-2 border-brand-teal"></div>
                        <div class="absolute top-4 right-4 w-12 h-12 border-t-2 border-r-2 border-brand-teal"></div>
                        <div class="absolute bottom-4 left-4 w-12 h-12 border-b-2 border-l-2 border-brand-teal"></div>
                        <div class="absolute bottom-4 right-4 w-12 h-12 border-b-2 border-r-2 border-brand-teal"></div>

                        <!-- Certificate Body Header Elements -->
                        <div class="text-center space-y-6 my-4">
                            <div class="flex justify-center mb-2">
                                <div class="bg-brand-navy text-brand-cyan p-3 rounded-full shadow-md">
                                    <i class="fa-solid fa-shield-halved text-2xl"></i>
                                </div>
                            </div>
                            <h2 class="certificate-title text-2xl md:text-3xl font-extrabold text-brand-navy tracking-wide uppercase">Certificate of Graduation</h2>
                            <p class="text-xs tracking-widest font-bold uppercase text-brand-teal font-mono">Secure Verification Registry Node</p>
                            
                            <div class="h-0.5 w-32 bg-gradient-to-r from-transparent via-brand-teal to-transparent mx-auto"></div>
                            
                            <p class="certificate-body text-base italic text-slate-500">This authentic electronic record validates that</p>
                            <h3 class="certificate-title text-xl md:text-2xl font-bold text-brand-navy border-b border-slate-200 pb-2 max-w-md mx-auto">Chinedu Silas Okeke</h3>
                            
                            <p class="certificate-body text-sm max-w-md mx-auto text-slate-600 leading-relaxed">
                                Has satisfied all academic requirements and successfully passed the assigned evaluation maps to graduate with a 
                            </p>
                            
                            <p class="certificate-title text-base font-bold text-brand-teal uppercase tracking-wider">
                                Second Class Upper Division (2:1)
                            </p>
                            
                            <p class="certificate-body text-xs text-slate-500">in the field of study program major</p>
                            <p class="certificate-title text-md font-bold text-brand-navy">Bachelor of Science in Computer Science</p>
                        </div>

                        <!-- Footer Layout Signatures & Security Elements inside Certificate -->
                        <div class="grid grid-cols-2 gap-4 mt-12 pt-6 border-t border-slate-100 items-end">
                            <div class="text-left space-y-1">
                                <p class="text-[10px] font-mono font-bold text-slate-400 uppercase tracking-wider">Matriculation Index</p>
                                <p class="text-xs font-mono font-bold text-brand-navy">2021/EG/1045</p>
                                <p class="text-[10px] font-mono text-slate-400 mt-2">CGPA Matrix: <span class="text-brand-navy font-bold">4.45 / 5.00</span></p>
                            </div>
                            <div class="text-right flex flex-col items-end space-y-1">
                                <!-- Secure System Stamp Mockup -->
                                <div class="w-12 h-12 border-2 border-dashed border-brand-teal rounded-full flex items-center justify-center text-brand-teal text-[9px] font-mono uppercase font-bold tracking-tighter rotate-12 mb-1">
                                    Secured
                                </div>
                                <p class="text-[10px] font-mono font-bold text-slate-400 uppercase tracking-wider">System Anchor</p>
                                <p class="text-xs font-mono text-slate-500">CertiGuard Secure Mint</p>
                            </div>
                        </div>

                        <!-- Bottom Signature Fingerprint Hash Representation footer line -->
                        <div class="mt-6 pt-4 border-t border-dashed border-slate-200 text-center">
                            <p class="text-[9px] font-mono text-slate-400 uppercase tracking-wider">SHA-256 Immutability Checksum Key</p>
                            <p class="text-[10px] font-mono text-brand-teal break-all mt-0.5 select-all">8f43a291e1029c32bca612984efd11029348abedef71203948eacd32109ffb3a</p>
                        </div>
                    </div>
                </section>

                <!-- REGISTRY DATABASE RECORD VIEW DATA-GRID TABLE (2 Columns wide) -->
                <section id="records-section" class="lg:col-span-2 bg-white p-6 rounded-2xl border border-slate-200 shadow-sm flex flex-col justify-between" data-aos="fade-left">
                    <div>
                        <div class="flex items-center justify-between mb-6 flex-wrap gap-2">
                            <div>
                                <h2 class="text-base font-extrabold text-brand-navy tracking-tight flex items-center space-x-2">
                                    <i class="fa-solid fa-server text-brand-teal"></i>
                                    <span>Cryptographic Meta Logs</span>
                                </h2>
                                <p class="text-xs text-slate-400 mt-1">Detailed system mappings for current active entity query string matches.</p>
                            </div>
                        </div>

                        <!-- Technical Parameter Metadata Rows -->
                        <div class="space-y-3.5">
                            <div class="p-3.5 bg-brand-slate rounded-xl border border-slate-100 space-y-1">
                                <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400 block">Database Origin Instance</span>
                                <span class="text-xs font-mono font-bold text-brand-navy">mongodb+srv://cluster0.certiguard.net</span>
                            </div>
                            <div class="p-3.5 bg-brand-slate rounded-xl border border-slate-100 space-y-1">
                                <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400 block">Encryption Block Layer</span>
                                <span class="text-xs font-mono font-bold text-brand-teal">CryptoJS / SHA-256 Buffer Pipeline</span>
                            </div>
                            <div class="p-3.5 bg-brand-slate rounded-xl border border-slate-100 space-y-1">
                                <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400 block">Verification Timestamp</span>
                                <span class="text-xs font-mono font-bold text-brand-navy">May 18, 2026 - 18:03:39 WAT</span>
                            </div>
                            <div class="p-3.5 bg-brand-slate rounded-xl border border-slate-100 space-y-1">
                                <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400 block">Security Handshake Token</span>
                                <span class="text-[11px] font-mono text-slate-500 break-all block">TLS_AES_256_GCM_SHA384_NodeConnectionSessionValid</span>
                            </div>
                        </div>
                    </div>

                    <!-- Action Link Route Back Home UI elements -->
                    <div class="border-t border-slate-100 pt-4 mt-6">
                        <a href="dashboard.html" class="w-full bg-brand-slate hover:bg-slate-200 text-brand-navy font-bold py-2.5 px-4 rounded-xl border border-slate-200 transition-all flex items-center justify-center space-x-2 text-xs">
                            <i class="fa-solid fa-arrow-left"></i>
                            <span>Return to Control Console</span>
                        </a>
                    </div>
                </section>

            </div>
        </main>

        <!-- SECURE PORTAL BANNER FOOTER -->
        <footer class="bg-white border-t border-slate-200 py-4 px-8 text-center text-xs text-slate-400 font-medium">
            <p>&copy; 2026 Institutional Verification Management Platform. Secure Administrative Node Access Session.</p>
        </footer>
    </div>

    <!-- LAYER BACKDROP CONTROL OVERLAY (Triggers on responsive active states) -->
    <div id="sidebar-overlay" onclick="toggleSidebar()" class="hidden fixed inset-0 z-30 bg-brand-navy/40 backdrop-blur-sm lg:hidden transition-all duration-300"></div>

    <!-- AOS ANIMATION INITIALIZATION & DRAWER CONTROL SCRIPTS -->
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({
            once: true,
            duration: 600,
            easing: 'ease-out-quad'
        });

        // Toggle Sidebar state switches supporting responsive mobile overlay drawer configurations
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebar-overlay');
            
            sidebar.classList.toggle('-translate-x-full');
            boxOverlay = overlay.classList.toggle('hidden');
        }
    </script>
</body>
</html>