<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Portal Login | CertiGuard</title>
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            navy: '#0A192F',       // Primary: Authoritative Dark Navy
                            cyan: '#00F0FF',       // Secondary: Tech/Security Accent Cyan
                            teal: '#0D9488',       // Accent Action Teal
                            slate: '#F8FAFC',      // Neutral Light: Clean Backgrounds
                            charcoal: '#334155',   // Text Gray
                        }
                    }
                }
            }
        }
    </script>

    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- AOS (Animate on Scroll) CSS -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <style>
        html, body {
            height: 100%;
        }
        /* Custom subtle glow on focus elements */
        .input-glow:focus {
            box-shadow: 0 0 15px rgba(0, 240, 255, 0.2);
            border-color: #00F0FF;
        }
    </style>
</head>
<body class="bg-brand-navy text-brand-charcoal font-sans antialiased flex flex-col min-h-screen selection:bg-brand-cyan selection:text-brand-navy">
<div id="formToast" class="fixed top-10 left-1/2 -translate-x-1/2 z-[10000] transform -translate-y-20 opacity-0 transition-all duration-500 pointer-events-none">
        <div class="bg-white border-l-4 border-red-500 shadow-2xl rounded-xl p-4 flex items-center space-x-4 min-w-[320px]">
            <div id="toastIconBg" class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0">
                <i id="toastIcon" class="fas fa-exclamation-triangle text-white"></i>
            </div>
            
            <div class="flex-1">
                <p id="toastTitle" class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-0.5">System Alert</p>
                <p id="toastMessage" class="text-sm font-bold text-slate-800">Invalid Input Detected</p>
            </div>
            
            <button onclick="appNotify.hide()" class="text-slate-300 hover:text-slate-600 transition">
                <i class="fas fa-times"></i>
            </button>
        </div>
    </div>
    <!-- MINIMALIST SECURE HEADER BAR -->
    <header class="w-full bg-brand-navy/80 backdrop-blur-md border-b border-brand-cyan/10 px-6 py-4 md:px-12">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <!-- Brand Logo -->
            <a href="index.html" class="flex items-center space-x-3 group">
                <div class="bg-gradient-to-tr from-brand-teal to-brand-cyan p-2.5 rounded-xl shadow-md transition-transform duration-300 group-hover:rotate-12">
                    <i class="fa-solid fa-shield-halved text-brand-navy text-xl"></i>
                </div>
                <span class="font-bold text-xl tracking-tight bg-gradient-to-r from-white to-slate-300 bg-clip-text text-transparent">
                    Certi<span class="text-brand-cyan">Guard</span>
                </span>
            </a>

            <!-- Return Home link -->
            <a href="index.html" class="text-sm font-semibold text-slate-400 hover:text-brand-cyan transition-colors flex items-center space-x-2">
                <i class="fa-solid fa-arrow-left text-xs"></i>
                <span>Back to Home</span>
            </a>
        </div>
    </header>

    <!-- MAIN INTERACTIVE LOGIN WRAPPER -->
    <main class="flex-grow flex items-center justify-center px-4 py-12 relative overflow-hidden">
        <!-- Abstract Security Geometric Orbs -->
        <div class="absolute -top-20 -right-20 w-80 h-80 bg-brand-cyan/10 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-20 -left-20 w-80 h-80 bg-brand-teal/10 rounded-full blur-3xl"></div>
        <div class="absolute inset-0 opacity-5 bg-[radial-gradient(#00F0FF_1px,transparent_1px)] [background-size:20px_20px] pointer-events-none"></div>

       <!-- Central Login Container Card Layout -->
<div data-aos="zoom-in" data-aos-duration="600" class="w-full max-w-sm bg-white/95 backdrop-blur-md rounded-2xl shadow-2xl p-6 md:p-8 border border-white/20 relative z-10 mx-auto">
    
    <!-- Context Welcoming Section (Made more compact) -->
    <div class="text-center mb-6">
        <div class="w-12 h-12 bg-brand-navy rounded-xl flex items-center justify-center mx-auto mb-3 shadow-lg border border-brand-cyan/20">
            <i class="fa-solid fa-lock-open text-xl text-brand-cyan"></i>
        </div>
        <h1 class="text-xl font-extrabold text-brand-navy tracking-tight">Institutional Portal Access</h1>
        <p class="text-[10px] font-bold uppercase tracking-wider text-brand-teal mt-0.5">Authorized Administration Only</p>
    </div>

    <!-- Action Security Login Form -->
    <form id="form">
        
        <!-- System Feedback Error/Success Container (Hidden by default) -->
        <div id="form-feedback" class="hidden p-3 rounded-xl text-xs font-semibold flex items-center space-x-2"></div>

        <!-- Input Item: Admin Staff Identification Key -->
        <div class="space-y-1">
            <label class="text-[11px] font-bold text-slate-700 uppercase tracking-wide flex items-center justify-between">
                <span>Staff Identification Key / Email</span>
                <i class="fa-solid fa-user text-slate-400"></i>
            </label>
            <div class="relative">
                <input name="email" type="text" id="admin-id" autocomplete="username" placeholder="admin@university.edu.ng" 
                    class="w-full px-3.5 py-2.5 rounded-xl bg-brand-slate border border-slate-200 text-sm font-medium text-brand-navy placeholder-slate-400 focus:outline-none focus:bg-white input-glow transition-all">
            </div>
        </div>

        <!-- Input Item: Vault Access Password Credentials -->
        <div class="space-y-1">
            <label class="text-[11px] font-bold text-slate-700 uppercase tracking-wide flex items-center justify-between">
                <span>Portal System Password</span>
                <i class="fa-solid fa-key text-slate-400"></i>
            </label>
            <div class="relative">
                <input name="password" type="password" id="admin-password" autocomplete="current-password" placeholder="••••••••••••" 
                    class="w-full pl-3.5 pr-10 py-2.5 rounded-xl bg-brand-slate border border-slate-200 text-sm font-medium text-brand-navy placeholder-slate-400 focus:outline-none focus:bg-white input-glow transition-all">
                
                <!-- Toggle Password Visibility Icon Trigger -->
                <button type="button" onclick="togglePasswordVisibility()" class="absolute right-3.5 top-1/2 -translate-y-1/2 text-slate-400 hover:text-brand-navy transition-colors focus:outline-none" aria-label="Toggle password text field visibility">
                    <i id="password-toggle-icon" class="fa-solid fa-eye-slash text-xs"></i>
                </button>
            </div>
        </div>

       

        <!-- Action Access Execution Button Submit Object -->
        <button type="submit" class="w-full bg-brand-navy hover:bg-brand-navy/95 text-white font-bold py-3 px-5 rounded-xl shadow-md transform hover:-translate-y-0.5 active:scale-95 transition-all flex items-center justify-center space-x-2 text-sm mt-2">
            <i class="fa-solid fa-right-to-bracket text-xs text-brand-cyan"></i>
            <span>Authenticate Log In</span>
        </button>

        <!-- Dynamic Redirection: Registration Link Component -->
        <div class="text-center pt-3 border-t border-slate-100 mt-4">
            <p class="text-xs text-slate-500">
                New system administrator? 
                <a href="/register" class="text-brand-teal font-bold hover:underline ml-1 inline-flex items-center">
                    Register Here <i class="fa-solid fa-arrow-right-long text-[10px] ml-1"></i>
                </a>
            </p>
        </div>
    </form>
</div>
    </main>

    <!-- COMPLIANCE AUDIT BOUNDS FOOTER BANNER -->
    <footer class="w-full border-t border-white/5 py-6 px-6 text-center text-xs text-slate-500 bg-black/20">
        <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between space-y-2 sm:space-y-0">
            <p>&copy; 2026 Academic Verification System Admin Portal Layer. Secure Token Node Operations.</p>
            <p class="flex items-center text-slate-400 font-mono text-[11px]">
                <span class="w-2 h-2 bg-emerald-400 rounded-full inline-block mr-2 animate-pulse"></span> AES-256 System Encryption Active
            </p>
        </div>
    </footer>

    <!-- AOS ANIMATION LIFECYCLE SCRIPTS -->
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="/formHandlers/login.js"></script>
    <script>
        AOS.init({
            once: true,
            duration: 500,
            easing: 'ease-out-quad'
        });

        // Toggle Visibility Parameter of Secure Hidden Inputs
        function togglePasswordVisibility() {
            const passwordInput = document.getElementById('admin-password');
            const toggleIcon = document.getElementById('password-toggle-icon');

            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.classList.remove('fa-eye-slash');
                toggleIcon.classList.add('fa-eye');
                toggleIcon.classList.add('text-brand-teal');
            } else {
                passwordInput.type = 'password';
                toggleIcon.classList.remove('fa-eye');
                toggleIcon.classList.add('fa-eye-slash');
                toggleIcon.classList.remove('text-brand-teal');
            }
        }

        // Dummy Demo Front-End Verification Controller Intercept Hook
        function validateLogin(e) {
            e.preventDefault();
            const feedbackBlock = document.getElementById('form-feedback');
            const adminId = document.getElementById('admin-id').value;
            
            // Show processing status UI changes
            feedbackBlock.classList.remove('hidden', 'bg-red-500/10', 'text-red-500');
            feedbackBlock.classList.add('bg-brand-cyan/10', 'text-brand-navy', 'block');
            feedbackBlock.innerHTML = `<i class="fa-solid fa-spinner animate-spin mr-1.5"></i> Processing session key evaluation arrays...`;

            // Simulation of local structural security evaluation mapping
            setTimeout(() => {
                feedbackBlock.classList.remove('bg-brand-cyan/10', 'text-brand-navy');
                feedbackBlock.classList.add('bg-red-500/10', 'text-red-500');
                feedbackBlock.innerHTML = `<i class="fa-solid fa-circle-exclamation mr-1.5"></i> Authentication mismatch: Internal API routing handles backend requests inside Node.js system endpoints.`;
            }, 1000);

            return false;
        }
    </script>
</body>
</html>