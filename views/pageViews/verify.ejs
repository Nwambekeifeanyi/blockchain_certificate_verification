<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Public Credential Verification | CertiGuard</title>
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            navy: '#0A192F',       // Primary Deep Navy
                            cyan: '#00F0FF',       // Security Accent Cyan
                            teal: '#0D9488',       // Secondary Operations Teal
                            slate: '#F8FAFC',      // Off-White Backgrounds
                            charcoal: '#334155',   // Text Typography Slate
                        }
                    }
                }
            }
        }
    </script>

    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <!-- AOS (Animate on Scroll) CSS -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <style>
        .drag-active {
            border-color: #00F0FF !important;
            background-color: rgba(0, 240, 255, 0.03) !important;
        }
    </style>
</head>
<body class="bg-brand-slate text-brand-charcoal font-sans antialiased selection:bg-brand-cyan selection:text-brand-navy">

     <div id="formToast" class="fixed top-10 left-1/2 -translate-x-1/2 z-[10000] transform -translate-y-20 opacity-0 transition-all duration-500 pointer-events-none">
        <div class="bg-white border-l-4 border-red-500 shadow-2xl rounded-xl p-4 flex items-center space-x-4 min-w-[320px]">
            <div id="toastIconBg" class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0">
                <i id="toastIcon" class="fas fa-exclamation-triangle text-white"></i>
            </div>
            <div class="flex-1">
                <p id="toastTitle" class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-0.5">System Alert</p>
                <p id="toastMessage" class="text-sm font-bold text-slate-800">Invalid Input Detected</p>
            </div>
            <button onclick="appNotify.hide()" class="text-slate-300 hover:text-slate-600 transition">
                <i class="fas fa-times"></i>
            </button>
        </div>
    </div>
    
    <!-- PUBLIC HEADER HEADER -->
    <header class="w-full bg-white border-b border-slate-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
            <a href="/" class="flex items-center space-x-2">
                <div class="w-8 h-8 bg-brand-navy rounded-lg flex items-center justify-center text-brand-cyan font-black text-sm shadow-sm">
                    CG
                </div>
                <span class="font-black text-brand-navy tracking-tight text-lg">Certi<span class="text-brand-teal">Guard</span></span>
            </a>
            <nav class="flex items-center space-x-6 text-xs font-bold text-brand-charcoal">
                <a href="/" class="hover:text-brand-teal transition-colors">Home</a>
                <a href="verify" class="text-brand-teal">Verify Portal</a>
                <a href="/login" class="bg-brand-navy text-white px-4 py-2 rounded-xl hover:bg-brand-navy/90 transition-all shadow-sm">Institution Login</a>
            </nav>
        </div>
    </header>

    <!-- MAIN BODY SECTION CONTAINER -->
    <main class="min-h-[calc(100vh-4rem)] flex flex-col justify-center items-center px-4 py-12 bg-gradient-to-b from-white to-brand-slate">
        
        <div class="max-w-4xl w-full grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
            
            <!-- LEFT COLUMN: EXPLANATORY MARKETING COPY -->
            <div class="lg:col-span-5 space-y-4 text-center lg:text-left" data-aos="fade-right">
                <div class="inline-flex items-center space-x-1.5 bg-brand-teal/10 text-brand-teal px-3 py-1 rounded-full text-[11px] font-bold tracking-wider uppercase">
                    <i class="fa-solid fa-shield-halved"></i> <span>Instant Integrity Check</span>
                </div>
                <h1 class="text-3xl md:text-4xl font-black text-brand-navy tracking-tight leading-none">
                    Verifying Graduate Credentials.
                </h1>
                <p class="text-xs text-slate-500 leading-relaxed max-w-md mx-auto lg:mx-0">
                    Guard against certificate forgery instantly. Employers and vetting agencies can confirm graduation compliance by querying academic files or identity indices directly against institutional ledgers.
                </p>
                <div class="pt-2 hidden lg:flex items-center space-x-4 text-xs font-semibold text-slate-400">
                    <span class="flex items-center gap-1.5"><i class="fa-solid fa-circle-check text-emerald-500"></i> Cryptographic Hash</span>
                    <span class="flex items-center gap-1.5"><i class="fa-solid fa-circle-check text-emerald-500"></i> Direct Database Sync</span>
                </div>
            </div>

            <!-- RIGHT COLUMN: INTERACTIVE FORM CORE -->
            <div class="lg:col-span-7 w-full" id="verify" data-aos="fade-left" data-aos-delay="100">
                <div class="bg-white p-6 md:p-8 rounded-3xl border border-slate-200/80 shadow-xl shadow-slate-200/50 relative overflow-hidden">
                    
                    <!-- Decorative glowing gradient accent background item -->
                    <div class="absolute -top-10 -right-10 w-32 h-32 bg-brand-cyan/10 rounded-full blur-2xl pointer-events-none"></div>

                    <form method="POST" enctype="multipart/form-data" class="space-y-6">
                        
                        <!-- METHOD A: MATRICULATION INDICES SECTION -->
                        <div class="space-y-2">
                            <label for="matricNumber" class="text-xs font-bold text-brand-navy uppercase tracking-wider flex items-center gap-1.5">
                                <i class="fa-solid fa-fingerprint text-brand-teal"></i> Method 1: Matriculation Number
                            </label>
                            <div class="relative">
                                <input type="text" id="matricNumber" name="matricNumber" placeholder="e.g., 2021/EG/1045"
                                    class="w-full pl-4 pr-12 py-3 rounded-xl bg-brand-slate border border-slate-200 text-xs font-semibold text-brand-navy placeholder:text-slate-400 focus:outline-none focus:bg-white focus:border-brand-teal focus:ring-4 focus:ring-brand-teal/5 transition-all uppercase tracking-wide">
                                <div class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-300">
                                    <i class="fa-solid fa-id-badge text-sm"></i>
                                </div>
                            </div>
                        </div>

                        <!-- LOGICAL DIVISION VISUAL SPLIT -->
                        <div class="relative flex py-2 items-center">
                            <div class="flex-grow border-t border-slate-100"></div>
                            <span class="flex-shrink mx-4 text-[10px] font-bold text-slate-400 uppercase tracking-widest bg-white px-2">OR</span>
                            <div class="flex-grow border-t border-slate-100"></div>
                        </div>

                        <!-- METHOD B: DOCUMENT FILE MATCHING DROPZONE -->
                        <div class="space-y-2">
                            <label class="text-xs font-bold text-brand-navy uppercase tracking-wider flex items-center gap-1.5">
                                <i class="fa-solid fa-file-shield text-brand-teal"></i> Method 2: Upload Digital Certificate
                            </label>
                            
                            <div id="dropzone" class="relative border-2 border-dashed border-slate-200 hover:border-brand-teal bg-brand-slate rounded-2xl p-6 text-center transition-all cursor-pointer group flex flex-col items-center justify-center min-h-[140px]">
                                <input type="file" id="certificateFile" name="certificateFile" accept=".pdf,.png,.jpg,.jpeg" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                                
                                <!-- Standby Initial State Display -->
                                <div id="prompt-state" class="space-y-1.5 pointer-events-none transition-all duration-300">
                                    <div class="text-slate-400 group-hover:text-brand-teal group-hover:scale-105 transition-all">
                                        <i class="fa-solid fa-file-import text-2xl"></i>
                                    </div>
                                    <div class="text-xs font-bold text-brand-navy">
                                        Drop certificate file here or <span class="text-brand-teal underline">browse</span>
                                    </div>
                                    <p class="text-[10px] text-slate-400 font-medium">Supports original clear PDF, PNG, or JPG formats</p>
                                </div>

                                <!-- Dynamic Success Input Filled State -->
                                <div id="success-state" class="hidden space-y-1.5 pointer-events-none text-center">
                                    <div class="text-emerald-500">
                                        <i class="fa-solid fa-shield-check text-2xl"></i>
                                    </div>
                                    <div class="text-xs font-black text-brand-navy truncate max-w-xs px-4" id="filename-output">
                                        Document Loaded
                                    </div>
                                    <p class="text-[10px] text-emerald-600 font-bold bg-emerald-50 px-2 py-0.5 rounded border border-emerald-100 inline-block">File appended successfully</p>
                                </div>
                            </div>
                        </div>

                        <!-- SYSTEM WARNING CAPTION DISCLOSURE -->
                        <p class="text-[10px] text-slate-400 leading-relaxed text-center bg-slate-50 p-3 rounded-xl border border-slate-100">
                            <i class="fa-solid fa-circle-info text-brand-teal mr-0.5"></i> 
                            By executing verification queries, you confirm your legal entitlement to validate the specified graduate profile matching data disclosure laws.
                        </p>

                        <!-- COMPLIANCE SUBMISSION LAUNCH BLOCK -->
                        <button type="submit" class="w-full bg-brand-navy hover:bg-brand-navy/95 text-white font-bold text-xs py-3.5 px-6 rounded-xl flex items-center justify-center space-x-2 transition-all shadow-md shadow-brand-navy/10 group">
                            <i class="fa-solid fa-magnifying-glass-chart text-brand-cyan group-hover:rotate-12 transition-transform"></i>
                            <span>Query Verification Infrastructure</span>
                        </button>
                    </form>

                </div>
            </div>

        </div>
    </main>

    <!-- FOOTER LINKS SECTION -->
    <footer class="bg-white border-t border-slate-200 py-6 text-center text-xs text-slate-400 font-medium">
        <div class="max-w-7xl mx-auto px-4 flex flex-col sm:flex-row items-center justify-between gap-4">
            <p>&copy; 2026 CertiGuard. Open Verification Public Ledger Access Node.</p>
            <div class="flex space-x-4 text-[11px]">
                <a href="#" class="hover:text-brand-navy transition-colors">Privacy Framework</a>
                <a href="#" class="hover:text-brand-navy transition-colors">Validation API</a>
            </div>
        </div>
    </footer>

    <!-- INTERACTIVE EVENT UTILITY LOGIC SCRIPTS -->
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="/formHandlers/verify.js"></script>
    <script>
        AOS.init({
            once: true,
            duration: 600,
            easing: 'ease-out-cubic'
        });

        // Interactive UI File Handlers
        const dropzone = document.getElementById('dropzone');
        const fileInput = document.getElementById('certificateFile');
        const promptState = document.getElementById('prompt-state');
        const successState = document.getElementById('success-state');
        const filenameOutput = document.getElementById('filename-output');

        ['dragenter', 'dragover'].forEach(eventName => {
            dropzone.addEventListener(eventName, (e) => {
                e.preventDefault();
                dropzone.classList.add('drag-active');
            }, false);
        });

        ['dragleave', 'drop'].forEach(eventName => {
            dropzone.addEventListener(eventName, (e) => {
                e.preventDefault();
                dropzone.classList.remove('drag-active');
            }, false);
        });

        fileInput.addEventListener('change', () => {
            const uploadedFile = fileInput.files[0];
            if(uploadedFile) {
                filenameOutput.textContent = uploadedFile.name;
                promptState.classList.add('hidden');
                successState.classList.remove('hidden');
                dropzone.classList.add('border-emerald-500', 'bg-emerald-50/5');
            }
        });
    </script>
</body>
</html>